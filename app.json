{
  "expo": {
    "name": "ClipartAI",
    "slug": "clipartai",
    "version": "1.0.0",
    "scheme": "clipartai",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.clipartai.app",
      "adaptiveIcon": {
        "backgroundColor": "#7C3AED"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-media-library"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "876e75d5-ea3d-4def-b568-efda901108ae"
      }
    }
  }
}
